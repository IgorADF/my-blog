---
import Layout from "../layouts/Layout.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
---

<Layout>
  <section
    class="mx-auto flex min-h-[70vh] max-w-2xl flex-col items-center justify-center px-4 py-16 text-center"
  >
    <p
      class="text-sm font-medium tracking-widest text-muted-foreground uppercase"
    >
      Error 404
    </p>
    <h1
      class="mt-3 text-5xl font-bold tracking-tight text-foreground sm:text-6xl"
    >
      Post not found
    </h1>
    <p class="mt-4 text-lg text-muted-foreground">
      The page you are looking for does not exist or has been removed.
    </p>

    <a
      href="/"
      class={cn(
        buttonVariants({ variant: "default", size: "sm" }),
        "mt-8 w-28",
      )}
    >
      Back to home
    </a>
  </section>
</Layout>
